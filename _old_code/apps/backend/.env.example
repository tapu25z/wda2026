# Server Configuration
PORT=4000
AI_SERVICE_URL=http://localhost:8000
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration (MongoDB)
# Format: mongodb://username:password@host:port/database?authSource=admin
DB_URI=mongodb://admin:your_password@localhost:27018/agriscan?authSource=admin

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# SMTP / Email Configuration (Google App Password)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Facebook OAuth Configuration
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# Redirect URLs
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/callback

# External API Keys (OpenWeatherMap, etc.)
OWM_API_KEY=your_open_weather_map_api_key